# ============================================================
# Database Configuration - WMS Hub
# ============================================================
# Copy file này thành db.properties và chỉnh sửa theo môi trường của bạn
# Hoặc sử dụng Environment Variables (ưu tiên hơn)

# Database Connection
db.host=localhost
db.port=3306
db.name=wms_hub
db.username=root
db.password=

# Connection Pool
db.pool.minIdle=5
db.pool.maxSize=30
db.pool.connectionTimeout=30000
db.pool.idleTimeout=600000
db.pool.maxLifetime=1800000

# Migration Path (thường không cần thay đổi)
# db.migration.path=/db/migration
