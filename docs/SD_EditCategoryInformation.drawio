        <!--  LEGEND                                                   -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <mxCell id="legend" value="CHÚ THÍCH&#xa;──────────────────────────────────&#xa;→  Synchronous call (solid arrow)&#xa;--→ Return / Response (dashed arrow)&#xa;▐   Activation bar (#00CCFF)&#xa;&#xa;LOGIC PHÂN NHÁNH CHÍNH&#xa;──────────────────────────────────&#xa;• existing.isImmutable() == true:&#xa;  → Chỉ cập nhật name, description, parentId&#xa;  → KHÔNG cập nhật category_code&#xa;  → Gọi update(category, false)&#xa;&#xa;• existing.isImmutable() == false:&#xa;  → Cho phép cập nhật category_code&#xa;  → Kiểm tra hasProducts + existsByCategoryCode&#xa;  → Gọi update(category, true)&#xa;  → Sau update: setImmutable(true) — khóa vĩnh viễn" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E6F3FF;strokeColor=#006EAF;fontSize=10;fontStyle=0;align=left;spacingLeft=10;spacingTop=5;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1690" width="310" height="290" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
