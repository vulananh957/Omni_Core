        <mxCell id="ret_svc_toggle" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;labelBackgroundColor=white;strokeColor=#10375C;fontSize=10;fontColor=#10375C;" value="boolean success">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="805" y="1160" as="sourcePoint" />
            <mxPoint x="565" y="1160" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Return HTTP response toggle -->
        <mxCell id="ret_http_toggle" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;labelBackgroundColor=white;strokeColor=#10375C;fontSize=10;fontColor=#10375C;" value="2.2.2. AJAX JSON Response {&quot;success&quot;: true}">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="565" y="1220" as="sourcePoint" />
            <mxPoint x="325" y="1220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Render UI toggle -->
        <mxCell id="msg2_3_render" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;labelBackgroundColor=white;strokeColor=#10375C;fontSize=11;fontColor=#10375C;fontStyle=0;" value="2.3. Displays success Toast notification">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="325" y="1250" as="sourcePoint" />
            <mxPoint x="100" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 3: Final state -->
        <mxCell id="msg3" edge="1" parent="1" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;labelBackgroundColor=white;strokeColor=#10375C;fontSize=11;fontColor=#10375C;fontStyle=0;" value="3. Dynamic modifications successfully applied and rendered without page reload">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="1470" as="sourcePoint" />
            <mxPoint x="325" y="1470" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
